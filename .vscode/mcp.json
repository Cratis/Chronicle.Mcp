{
    "servers": {
        "chronicle-mcp": {
            "type": "stdio",
            "command": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/Source/Chronicle.Mcp.csproj"
            ]
        },
        "Chronicle": {
            "type": "stdio",
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-eCratis__Chronicle__Mcp__ConnectionString=chronicle://localhost:35000",
                "cratis/chronicle-mcp"
            ]
        }
    }
}
